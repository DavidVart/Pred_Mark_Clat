# === Polymarket ===
POLYGON_WALLET_PRIVATE_KEY=

# === Kalshi ===
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem

# === LLMs (OpenRouter - single key for all models) ===
OPENROUTER_API_KEY=

# === Trading Mode ===
TRADING_MODE=paper

# === Risk Parameters ===
MAX_DAILY_LOSS_PCT=0.10
MAX_DRAWDOWN_PCT=0.15
KELLY_FRACTION=0.25
MAX_POSITION_SIZE_PCT=0.03
MAX_POSITIONS=10
MIN_EDGE=0.05
MIN_CONFIDENCE=0.45
MAX_SECTOR_CONCENTRATION=0.30

# === Cost Controls ===
DAILY_AI_COST_LIMIT=10.0

# === Database ===
DB_PATH=trading.db

# === Logging ===
LOG_LEVEL=INFO
